    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        // Gemini API Integration
        const apiKey = ""; // Execution environment provides this
        const btn = document.getElementById('generate-btn');
        const input = document.getElementById('inventory-problem');
        const loading = document.getElementById('loading-state');
        const output = document.getElementById('strategy-output');

        const systemPrompt = `You are the VDP Masters AI Intelligence Engine. A dealership user will provide an inventory problem (e.g., specific cars that aren't selling). 
        Your goal is to provide a highly analytical, aggressive, enterprise-grade predictive marketing strategy.
        
        Provide:
        1. A 3-step strategy to move that specific inventory using Direct-to-VDP targeting, market data, and competitor scraping.
        2. ONE sample of high-converting, punchy ad copy.

        FORMAT INSTRUCTIONS: 
        Respond ONLY using raw HTML tags so it renders beautifully in a web widget. Use <h4>, <p>, <ul>, <li>, and <strong>. 
        Wrap the ad copy in a <blockquote> tag. 
        DO NOT wrap the response in markdown blocks like \`\`\`html.
        Keep the entire response under 200 words. Be confident and authoritative.`;

        async function generateStrategy(query) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: query }] }],
                systemInstruction: { parts: [{ text: systemPrompt }] }
            };

            let retries = 5;
            let delay = 1000;
            
            for (let i = 0; i < retries; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    
                    if (!response.ok) throw new Error(`HTTP status: ${response.status}`);
                    
                    const data = await response.json();
                    return data.candidates?.[0]?.content?.parts?.[0]?.text || "<p>Failed to generate strategy.</p>";
                } catch (error) {
                    if (i === retries - 1) {
                        console.error('API Error:', error);
                        return `<p class="text-red-400">Connection to intelligence engine timed out. Please try again.</p>`;
                    }
                    await new Promise(r => setTimeout(r, delay));
                    delay *= 2; // Exponential backoff
                }
            }
        }

        btn.addEventListener('click', async () => {
            const query = input.value.trim();
            if (!query) {
                input.focus();
                return;
            }

            // Update UI to loading state
            btn.disabled = true;
            btn.innerHTML = 'Analyzing Market Data...';
            output.classList.add('hidden');
            loading.classList.remove('hidden');

            // Call Gemini
            const resultHtml = await generateStrategy(query);

            // Update UI with results
            output.innerHTML = resultHtml;
            loading.classList.add('hidden');
            output.classList.remove('hidden');
            
            btn.disabled = false;
            btn.innerHTML = '✨ Generate Another Strategy';
        });
    </script>
</body>
</html>
